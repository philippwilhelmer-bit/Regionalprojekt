// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ArticleStatus {
  FETCHED // raw item ingested from source
  TAGGED // Bezirk(e) assigned by AI — deprecated post-v3.2: written only when AI_USE_MERGED_CALL=false
  WRITTEN // AI-rewritten article ready
  REVIEW // flagged: named person detected
  PUBLISHED // live on site
  REJECTED // editor rejected
  ERROR // retryable failure — scheduler will retry
  FAILED // permanently excluded — max retries exceeded
}

enum ArticleSource {
  OTS_AT
  RSS
  MANUAL
}

enum AiTone {
  NEUTRAL
  FORMAL
  CONVERSATIONAL
}

enum AiArticleLength {
  SHORT
  MEDIUM
  LONG
}

model Bezirk {
  id               Int             @id @default(autoincrement())
  slug             String          @unique // e.g. "liezen", "graz"
  name             String          @unique // e.g. "Liezen", "Graz (Stadt)"
  gemeindeSynonyms String[] // AI geo-tagging hints, e.g. ["Ennstal", "Schladming"]
  articles         ArticleBezirk[]
  doctors          Doctor[]
  createdAt        DateTime        @default(now())

  @@index([slug])
}

model Article {
  id              Int             @id @default(autoincrement())
  publicId        String?         @unique @default(nanoid()) // stable reader-facing URL identifier
  externalId      String? // source system ID (e.g. OTS article ID)
  source          ArticleSource
  sourceId        Int?
  sourceFk        Source?         @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  status          ArticleStatus   @default(FETCHED)
  isStateWide     Boolean         @default(false) // "Steiermark-weit" flag
  isAutoGenerated Boolean         @default(true)
  title           String?
  metaDescription String?
  seoTitle        String?
  content         String?
  contentHash     String?         @unique // SHA-256 of normalized title+body for cross-source dedup
  rawPayload      Json? // original source content before AI rewrite
  publishedAt     DateTime?
  isPinned        Boolean         @default(false)
  isFeatured      Boolean         @default(false)
  isEilmeldung    Boolean         @default(false)
  imageUrl        String?
  imageCredit     String?
  theme           String?
  retryCount      Int             @default(0)
  errorMessage    String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  bezirke         ArticleBezirk[]

  @@index([status])
  @@index([publishedAt])
  @@index([source, externalId])
  @@index([publicId])
  @@index([isPinned, isFeatured])
  @@index([isEilmeldung])
  @@index([source, status])
  @@index([sourceId])
  @@index([theme])
}

model ArticleBezirk {
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId Int
  bezirk    Bezirk   @relation(fields: [bezirkId], references: [id])
  bezirkId  Int
  taggedAt  DateTime @default(now())

  @@id([articleId, bezirkId])
  @@index([bezirkId])
}

enum SourceHealth {
  OK
  DEGRADED
  DOWN
}

model Source {
  id                     Int             @id @default(autoincrement())
  type                   ArticleSource // OTS_AT or RSS only — MANUAL sources are not polled
  url                    String          @unique
  enabled                Boolean         @default(true)
  pollIntervalMinutes    Int             @default(15)
  consecutiveFailures    Int             @default(0)
  lastSuccessAt          DateTime?
  healthStatus           SourceHealth    @default(OK)
  healthFailureThreshold Int             @default(3)
  category               String? // OTS RSS category: politik, wirtschaft, kultur, medien, chronik, sport
  keywords               String[]        @default([]) // Filter keywords — articles must contain at least one
  // Phase 44 (INGEST-03/04): polling cursor + HTTP cache validators (all nullable for back-compat)
  lastFetchedAt          DateTime? // OTS: last successful list-window upper bound; RSS: time of last 2xx/304
  etag                   String? // RSS conditional GET — If-None-Match
  lastModified           String? // RSS conditional GET — If-Modified-Since (RFC 7231 string, verbatim)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  articles               Article[]
  runs                   IngestionRun[]
  aiSourceConfig         AiSourceConfig?

  @@index([enabled])
}

model IngestionRun {
  id         Int       @id @default(autoincrement())
  source     Source    @relation(fields: [sourceId], references: [id])
  sourceId   Int
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  itemsFound Int?
  itemsNew   Int?
  error      String?

  @@index([sourceId, startedAt])
}

model PipelineRun {
  id                Int       @id @default(autoincrement())
  startedAt         DateTime  @default(now())
  finishedAt        DateTime?
  articlesProcessed Int?
  articlesWritten   Int?
  totalInputTokens  Int?
  totalOutputTokens Int?
  error             String?

  @@index([startedAt])
}

model AiConfig {
  id            Int             @id @default(autoincrement())
  tone          AiTone          @default(NEUTRAL)
  articleLength AiArticleLength @default(MEDIUM)
  styleNotes    String?
  modelOverride String?
  updatedAt     DateTime        @updatedAt
}

model AiSourceConfig {
  id            Int              @id @default(autoincrement())
  sourceId      Int              @unique
  source        Source           @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  tone          AiTone?
  articleLength AiArticleLength?
  styleNotes    String?
  modelOverride String?
  updatedAt     DateTime         @updatedAt
}

model PipelineConfig {
  id                    Int      @id @default(autoincrement())
  maxRetryCount         Int      @default(3)
  deadManThresholdHours Int      @default(6)
  updatedAt             DateTime @updatedAt
}

model GeocodingCache {
  id             Int      @id @default(autoincrement())
  normalizedName String   @unique
  displayName    String
  lat            Float
  lon            Float
  locationType   String
  cachedAt       DateTime @default(now())

  @@index([normalizedName])
}

enum Fachrichtung {
  ALLGEMEINMEDIZIN
  ALLGEMEINMEDIZIN_UND_FAMILIENMEDIZIN
  INNERE_MEDIZIN
  FRAUENHEILKUNDE_UND_GEBURTSHILFE
  AUGENHEILKUNDE_UND_OPTOMETRIE
  ALLGEMEINCHIRURGIE_UND_VISZERALCHIRURGIE
  ORTHOPAEDIE_UND_TRAUMATOLOGIE
  UNFALLCHIRURGIE
  ORTHOPAEDIE_UND_ORTHOPAEDISCHE_CHIRURGIE
  PSYCHIATRIE_U_PSYCHOTHERAPEUTISCHE_MEDIZIN
  HAUT_UND_GESCHLECHTSKRANKHEITEN
  KINDER_UND_JUGENDHEILKUNDE
  HALS_NASEN_UND_OHRENHEILKUNDE
  NEUROLOGIE
  RADIOLOGIE
  UROLOGIE
  ANAESTHESIOLOGIE_UND_INTENSIVMEDIZIN
  PLASTISCHE_REKONSTRUKTIVE_U_AESTHETISCHE_CHIRURGIE
  INNERE_MEDIZIN_UND_KARDIOLOGIE
  LUNGENKRANKHEITEN
  PSYCHIATRIE_UND_NEUROLOGIE
  MUND_KIEFER_UND_GESICHTSCHIRURGIE
  NEUROLOGIE_UND_PSYCHIATRIE
  NEUROCHIRURGIE
  KINDER_U_JUGENDPSYCHIATRIE_U_PSYCHOTHERAPEUTISCHE_MEDIZIN
  APPROBIERTER_ARZT
  MEDIZINISCHE_UND_CHEMISCHE_LABORDIAGNOSTIK
  PHYSIKALISCHE_MEDIZIN_U_ALLGEMEINE_REHABILITATION
  PSYCHIATRIE
  ALLGEMEINCHIRURGIE_UND_GEFAESSCHIRURGIE
  INNERE_MEDIZIN_UND_PNEUMOLOGIE
  NUKLEARMEDIZIN
  KINDER_UND_JUGENDPSYCHIATRIE
  KLINISCHE_PATHOLOGIE_UND_MOLEKULARPATHOLOGIE
  KINDER_UND_JUGENDCHIRURGIE
  HERZCHIRURGIE
  INNERE_MEDIZIN_UND_GASTROENTEROLOGIE_UND_HEPATOLOGIE
  KLINISCHE_MIKROBIOLOGIE_UND_HYGIENE
  STRAHLENTHERAPIE_RADIOONKOLOGIE
  ANATOMIE
  KLINISCHE_IMMUNOLOGIE
  THORAXCHIRURGIE
  ARBEITSMEDIZIN
  GERICHTSMEDIZIN
  INNERE_MEDIZIN_UND_ANGIOLOGIE
  INNERE_MEDIZIN_UND_ENDOKRINOLOGIE_U_DIABETOLOGIE
  INNERE_MEDIZIN_UND_HAEMATOLOGIE_UND_INTERNISTISCHE_ONKOLOGIE
  INNERE_MEDIZIN_UND_INFEKTIOLOGIE
  INNERE_MEDIZIN_UND_INTENSIVMEDIZIN
  INNERE_MEDIZIN_UND_NEPHROLOGIE
  MEDIZINISCHE_GENETIK
}

model Doctor {
  id                Int          @id @default(autoincrement())
  publicId          String       @unique @default(nanoid())
  arztNr            String       @unique
  name              String
  titel             String?
  fachrichtung      Fachrichtung
  address           String
  lat               Float?
  lon               Float?
  bezirk            Bezirk       @relation(fields: [bezirkId], references: [id])
  bezirkId          Int
  email             String?
  profilUrl         String?
  phone             String?
  editorialNote     String?
  relatedArticleIds String[]     @default([])
  mapImageUrl       String?
  isVerified        Boolean      @default(false)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([bezirkId])
  @@index([fachrichtung])
  @@index([isVerified, name])
}
